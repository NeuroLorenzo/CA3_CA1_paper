{
    "target_simulator": "NEST",
    "manifest": {
        "$BASE_DIR": ".",
        "$NETWORK_DIR": "$BASE_DIR/",
        "$COMPONENTS_DIR": "$BASE_DIR/",
        "$INPUT_DIR": "$BASE_DIR/inputs"
    },
    "components": {
        "point_neuron_models_dir": "$COMPONENTS_DIR/",
        "synaptic_models_dir": "$COMPONENTS_DIR/"
    },
    "networks": {
        "nodes": [
            {
                "nodes_file": "$NETWORK_DIR/CA3_comm_Network_nodes.h5",
                "node_types_file": "$NETWORK_DIR/CA3_comm_Network_node_types.csv"
            },
            {
                "nodes_file": "$NETWORK_DIR/INPUT_Network_nodes.h5",
                "node_types_file": "$NETWORK_DIR/INPUT_Network_node_types.csv"
            }
        ],
        "edges": [
            {
                "edges_file": "$NETWORK_DIR/CA3_comm_Network_CA3_comm_Network_edges.h5",
                "edge_types_file": "$NETWORK_DIR/CA3_comm_Network_CA3_comm_Network_edge_types.csv"
            },
            {
                "edges_file": "$NETWORK_DIR/INPUT_Network_CA3_comm_Network_edges.h5",
                "edge_types_file": "$NETWORK_DIR/INPUT_Network_CA3_comm_Network_edge_types.csv"
            }
        ]
    },
    "inputs": {
        "INPUT_Network_spike_trains": {
            "input_file": "$INPUT_DIR/INPUT_Network_spikes.h5",
            "node_set": "INPUT_Network"
        }
    },
    "run": {
        "tstop": 110000.0,
        "dt": 0.1,
        "rng_seed": 12345
    }
}